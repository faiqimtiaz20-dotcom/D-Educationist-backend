generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum Portal {
  admin
  partner
  student
}

enum DocStatus {
  Pending
  Completed
}

enum InvoiceStatus {
  Pending
  Partial_Paid @map("Partial Paid")
  Fully_Paid   @map("Fully Paid")
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  pending
  completed
}

enum CalendarCategory {
  enquiry
  student
  application
  visa
  invoice
}

enum CalendarEventType {
  followup
  appointment
  due
}

enum StudentDocumentStatus {
  Pending
  Uploaded
  Verified
  Rejected
}

enum MessageSender {
  student
  counsellor
}

enum AnnouncementPriority {
  normal
  high
}

enum InteractionKind {
  followup
  appointment
}

// ─── Platform & Identity ─────────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  logoUrl   String?
  settings  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  branches          Branch[]
  partners          Partner[]
  roles             Role[]
  users             User[]
  countries         Country[]
  intakes           Intake[]
  applyLevels       ApplyLevel[]
  sources           Source[]
  enquiries         Enquiry[]
  students          Student[]
  applications      Application[]
  visaRecords       VisaRecord[]
  deferRecords      DeferRecord[]
  enrolledRecords   EnrolledRecord[]
  invoices          Invoice[]
  partnerInvoices   PartnerInvoice[]
  universityCommissions UniversityCommission[]
  calendarEvents    CalendarEvent[]
  universityMasters UniversityMaster[]
  courses           Course[]
  masterItems       MasterItem[]
  auditLogs         AuditLog[]
  tasks             Task[]
  standardDocuments StandardDocument[]
  studentDocuments  StudentDocument[]
  entityNotes       EntityNote[]
  chatMessages      ChatMessage[]
  marketingCampaigns MarketingCampaign[]
  tenantIntegrations TenantIntegration[]
  qrForms           QrForm[]
  announcements        Announcement[]
  learningResources    LearningResource[]
  entityInteractions   EntityInteraction[]
  applicationComments  ApplicationComment[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  enquiries       Enquiry[]
  students        Student[]
  applications    Application[]
  visaRecords     VisaRecord[]
  deferRecords    DeferRecord[]
  enrolledRecords EnrolledRecord[]
  calendarEvents  CalendarEvent[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

model Partner {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  code         String
  contactEmail String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  enquiries       Enquiry[]
  students        Student[]
  applications    Application[]
  visaRecords     VisaRecord[]
  deferRecords    DeferRecord[]
  enrolledRecords EnrolledRecord[]
  invoices        Invoice[]
  partnerInvoices PartnerInvoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("partners")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  portal    Portal
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String?
  email        String
  passwordHash String
  name         String
  roleId       String
  branchId     String?
  partnerId    String?
  studentId    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role          Role           @relation(fields: [roleId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  partner       Partner?       @relation(fields: [partnerId], references: [id])
  student       Student?       @relation(fields: [studentId], references: [id])
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]
  passwordResetTokens   PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([roleId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Lookup / Master Data ──────────────────────────────────────────────────────

model Country {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("countries")
}

model Intake {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("intakes")
}

model ApplyLevel {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("apply_levels")
}

model Source {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sources")
}

model MasterItem {
  id        String   @id @default(cuid())
  tenantId  String
  category  String
  name      String
  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category, name])
  @@index([tenantId, category])
  @@map("master_items")
}

model Task {
  id          String       @id @default(cuid())
  tenantId    String
  title       String
  description String?
  dueDate     DateTime
  assignedTo  String
  status      TaskStatus   @default(pending)
  priority    TaskPriority @default(medium)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("tasks")
}

model StandardDocument {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  fileName  String
  filePath  String
  mimeType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("standard_documents")
}

model StudentDocument {
  id         String                @id @default(cuid())
  tenantId   String
  studentId  String
  name       String
  docType    String?
  status     StudentDocumentStatus @default(Pending)
  fileName   String?
  filePath   String?
  mimeType   String?
  remark     String?
  uploadedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@map("student_documents")
}

model EntityNote {
  id         String   @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  text       String
  authorName String
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("entity_notes")
}

model ChatMessage {
  id        String        @id @default(cuid())
  tenantId  String
  studentId String
  sender    MessageSender
  text      String
  createdAt DateTime      @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([studentId])
  @@map("chat_messages")
}

model MarketingCampaign {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  channel         String
  status          String
  startDate       DateTime
  endDate         DateTime
  description     String?
  audienceCountry String?
  audienceStatus  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("marketing_campaigns")
}

model TenantIntegration {
  id              String   @id @default(cuid())
  tenantId        String
  integrationKey  String
  connected       Boolean  @default(false)
  config          Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, integrationKey])
  @@index([tenantId])
  @@map("tenant_integrations")
}

model QrForm {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  assignTo  String
  fields    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("qr_forms")
}

model Announcement {
  id          String               @id @default(cuid())
  tenantId    String
  title       String
  body        String
  publishedAt DateTime
  priority    AnnouncementPriority @default(normal)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("announcements")
}

model LearningResource {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String
  type        String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("learning_resources")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Course {
  id        String   @id @default(cuid())
  tenantId  String
  country   String
  university String
  course    String
  level     String
  intake    String
  duration  String?
  tuition   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, country])
  @@map("courses")
}

model UniversityMaster {
  id                 String    @id @default(cuid())
  tenantId           String
  country            String
  name               String
  commissionContract String
  agreementExpiry    DateTime?
  agreementFileName  String?
  logoFileName       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campuses    UniversityCampus[]
  commissions UniversityCommission[]

  @@index([tenantId])
  @@index([tenantId, country])
  @@map("university_masters")
}

model UniversityCampus {
  id                 String @id @default(cuid())
  universityMasterId String
  name               String
  city               String?

  universityMaster UniversityMaster @relation(fields: [universityMasterId], references: [id], onDelete: Cascade)

  @@index([universityMasterId])
  @@map("university_campuses")
}

// ─── CRM Core ────────────────────────────────────────────────────────────────

model Enquiry {
  id                   String    @id @default(cuid())
  tenantId             String
  branchId             String
  partnerId            String?
  firstName            String
  lastName             String
  email                String
  mobile               String
  alternateNo          String?
  dateOfBirth          DateTime?
  gender               String?
  nationality          String?
  maritalStatus        String?
  address              String?
  highestQualification String?
  interestedCourse     String?
  testGiven            String?
  interestedCountry    String?
  intake               String?
  applyLevel           String?
  source               String?
  status               String
  remark               String?
  assignedBy           String
  assignedTo           String
  followUpDate         DateTime?
  followUpTime         String?
  followUpRemarks      String?
  appointmentDate      DateTime?
  appointmentTime      String?
  appointmentRemarks   String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch  Branch   @relation(fields: [branchId], references: [id])
  partner Partner? @relation(fields: [partnerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, partnerId])
  @@index([tenantId, branchId])
  @@map("enquiries")
}

model Student {
  id                   String    @id @default(cuid())
  tenantId             String
  branchId             String
  partnerId            String?
  studentRef           String
  firstName            String
  lastName             String
  email                String
  mobile               String
  alternateNo          String?
  dateOfBirth          DateTime?
  gender               String?
  nationality          String?
  maritalStatus        String?
  address              String?
  highestQualification String?
  interestedCourse     String?
  interestedCountry    String?
  intake               String?
  applyLevel           String?
  source               String?
  status               String
  docStatus            DocStatus @default(Pending)
  remark               String?
  passportNo           String?
  passportIssue        DateTime?
  passportExpiry       DateTime?
  assignedBy           String
  assignedTo           String
  followUpDate         DateTime?
  followUpTime         String?
  followUpRemarks      String?
  appointmentDate      DateTime?
  appointmentTime      String?
  appointmentRemarks   String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch                   @relation(fields: [branchId], references: [id])
  partner           Partner?                 @relation(fields: [partnerId], references: [id])
  users             User[]
  academics         StudentAcademic[]
  proficiencyTests  StudentProficiencyTest[]
  workExperience    StudentWorkExperience[]
  applications      Application[]
  visaRecords       VisaRecord[]
  deferRecords      DeferRecord[]
  enrolledRecords   EnrolledRecord[]
  invoices          Invoice[]
  studentDocuments  StudentDocument[]
  chatMessages      ChatMessage[]

  @@unique([tenantId, studentRef])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, partnerId])
  @@map("students")
}

model StudentAcademic {
  id            String @id @default(cuid())
  studentId     String
  qualification String
  subjects      String
  college       String
  percentage    String
  backlogs      String
  yearOfPassing String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_academics")
}

model StudentProficiencyTest {
  id        String    @id @default(cuid())
  studentId String
  type      String
  overall   String?
  listening String?
  reading   String?
  writing   String?
  speaking  String?
  testDate  DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_proficiency_tests")
}

model StudentWorkExperience {
  id              String    @id @default(cuid())
  studentId       String
  companyName     String
  position        String
  startDate       DateTime?
  endDate         DateTime?
  totalExperience String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_work_experience")
}

model Application {
  id                String    @id @default(cuid())
  tenantId          String
  studentId         String
  branchId          String
  partnerId         String?
  applicationCount  Int       @default(1)
  docStatus         DocStatus @default(Pending)
  intCountry        String
  intake            String
  intCourse         String
  applyLevel        String
  passportNo        String?
  dateOfBirth       DateTime?
  status            String
  university        String?
  associate         String?
  deadlineDate      DateTime?
  isPartner         Boolean   @default(false)
  assignedBy        String
  assignedTo        String
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  branch      Branch       @relation(fields: [branchId], references: [id])
  partner     Partner?     @relation(fields: [partnerId], references: [id])
  visaRecords VisaRecord[]
  comments    ApplicationComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, partnerId])
  @@index([studentId])
  @@map("applications")
}

model EntityInteraction {
  id         String          @id @default(cuid())
  tenantId   String
  entityType String
  entityId   String
  kind       InteractionKind
  action     String
  remarks    String
  stage      String
  attempt    Int
  nextDate   String?
  nextTime   String?
  authorName String
  userId     String?
  createdAt  DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId, kind])
  @@map("entity_interactions")
}

model ApplicationComment {
  id             String   @id @default(cuid())
  tenantId       String
  applicationId  String
  comment        String
  attachmentName String?
  authorName     String
  userId         String?
  createdAt      DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId, applicationId])
  @@map("application_comments")
}

model VisaRecord {
  id             String    @id @default(cuid())
  tenantId       String
  studentId      String
  applicationId  String?
  branchId       String
  partnerId      String?
  docStatus      DocStatus @default(Pending)
  appliedCountry String
  university     String
  visaStatus     String
  course         String
  intake         String
  passportNo     String?
  isPartner      Boolean   @default(false)
  assignedBy     String
  assignedTo     String
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id])
  branch      Branch       @relation(fields: [branchId], references: [id])
  partner     Partner?     @relation(fields: [partnerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, visaStatus])
  @@index([tenantId, partnerId])
  @@index([studentId])
  @@map("visa_records")
}

model DeferRecord {
  id                  String   @id @default(cuid())
  tenantId            String
  studentId           String
  branchId            String
  partnerId           String?
  deferIntake         String
  deferReason         String
  interestedCourse    String?
  interestedCountries String?
  applyLevel          String?
  source              String?
  intake              String?
  isPartner           Boolean  @default(false)
  assignedBy          String
  assignedTo          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  branch  Branch   @relation(fields: [branchId], references: [id])
  partner Partner? @relation(fields: [partnerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, partnerId])
  @@map("defer_records")
}

model EnrolledRecord {
  id                String   @id @default(cuid())
  tenantId          String
  studentId         String
  branchId          String
  partnerId         String?
  appliedCountry    String
  appliedUniversity String
  course            String
  intake            String
  status            String
  source            String?
  isPartner         Boolean  @default(false)
  assignedBy        String
  assignedTo        String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  branch  Branch   @relation(fields: [branchId], references: [id])
  partner Partner? @relation(fields: [partnerId], references: [id])

  @@index([tenantId])
  @@index([tenantId, partnerId])
  @@map("enrolled_records")
}

// ─── Financial ───────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  tenantId       String
  studentId      String
  partnerId      String?
  invoiceNo      String
  totalAmount    Decimal       @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  afterDiscount  Decimal       @db.Decimal(12, 2)
  taxPercent     Decimal       @default(0) @db.Decimal(5, 2)
  taxType        String        @default("GST")
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal       @db.Decimal(12, 2)
  dueDate        DateTime
  status         InvoiceStatus @default(Pending)
  serviceType    String
  currency       String        @default("PKR")
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  partner Partner? @relation(fields: [partnerId], references: [id])

  @@unique([tenantId, invoiceNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("invoices")
}

model PartnerInvoice {
  id                 String        @id @default(cuid())
  tenantId           String
  partnerId          String
  invoiceNo          String
  studentCount       Int           @default(0)
  netCommission      Decimal       @db.Decimal(12, 2)
  currency           String        @default("PKR")
  taxPercent         Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount          Decimal       @default(0) @db.Decimal(12, 2)
  totalCommission    Decimal       @db.Decimal(12, 2)
  receivedCommission Decimal       @default(0) @db.Decimal(12, 2)
  pendingCommission  Decimal       @db.Decimal(12, 2)
  status             InvoiceStatus @default(Pending)
  createdBy          String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceNo])
  @@index([tenantId])
  @@map("partner_invoices")
}

model UniversityCommission {
  id                 String        @id @default(cuid())
  tenantId           String
  universityMasterId String?
  invoiceNo          String
  country            String
  university         String
  studentCount       Int           @default(0)
  totalCommission    Decimal       @db.Decimal(12, 2)
  receivedCommission Decimal       @default(0) @db.Decimal(12, 2)
  pendingCommission  Decimal       @db.Decimal(12, 2)
  status             InvoiceStatus @default(Pending)
  createdBy          String
  commissionType     String
  commissionSubType  String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  universityMaster UniversityMaster? @relation(fields: [universityMasterId], references: [id])

  @@unique([tenantId, invoiceNo])
  @@index([tenantId])
  @@map("university_commissions")
}

// ─── Calendar & Audit ────────────────────────────────────────────────────────

model CalendarEvent {
  id        String            @id @default(cuid())
  tenantId  String
  branchId  String?
  staffId   String?
  title     String
  start     DateTime
  end       DateTime?
  category  CalendarCategory
  eventType CalendarEventType
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@map("calendar_events")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  entity    String
  entityId  String
  action    String
  meta      Json?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

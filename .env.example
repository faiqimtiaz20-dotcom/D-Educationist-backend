DATABASE_URL="postgresql://postgres:admin@localhost:5432/visa-d-database"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development
# No trailing slash — browsers send Origin without one (e.g. https://app.vercel.app)
CORS_ORIGIN="http://localhost:5173"

# On server startup (production): migrations run automatically.
# Seed runs once when the database has no tenants (empty DB).
# Deploy the full repo so seed can read Frontend/krs-crm-ui/src/mocks/data.
